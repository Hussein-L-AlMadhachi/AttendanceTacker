# Production .env — copy to project root as .env
#
# RULE: DB_HOST=postgres only works INSIDE Docker network on port 5432.
#       From the host (systemd backend, npm run db:*, psql) use localhost:5433.

JWT_SECRET=change-me

DB_HOST=localhost
DB_PORT=5433
POSTGRES_PUBLISH_PORT=5433
DB_NAME=attendance_trackeroo
DB_USER=dev
DB_PASSWORD=dev123456

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-too

BACKEND_PORT=3001
PORT=3001
NODE_ENV=production
NGINX_HOST=hada.aqaariq.com
