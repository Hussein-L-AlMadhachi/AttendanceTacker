# CENUSIS-Ops Environment Variables
# Copy this file to .env and update with your values

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=ST8LQfVnparKYIN0CEx5FYRjL3noWL4CaEjTm9breZI=

# Database Configuration
# Docker backend → use DB_HOST=postgres and DB_PORT=5432 (internal container port)
# Host tools / systemd backend → use DB_HOST=localhost and DB_PORT=5433
DB_HOST=postgres
DB_PORT=5432
POSTGRES_PUBLISH_PORT=5433
DB_NAME=cenusis_ops
DB_USER=dev
DB_PASSWORD=12345678

# Node Environment
NODE_ENV=production

# Network Configuration
# Set this to your server's IP address or domain name
# Examples: 192.168.1.100, example.com, app.example.com
NGINX_HOST=localhost
