# CENUSIS-Ops Environment Variables
# Copy this file to .env and update with your values

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=ST8LQfVnparKYIN0CEx5FYRjL3noWL4CaEjTm9breZI=

# Database credentials (shared by postgres container + app)
# HOST CONNECTION (systemd backend, npm run db:*, psql from server):
#   DB_HOST=localhost  DB_PORT=5433  (same as POSTGRES_PUBLISH_PORT)
# DOCKER BACKEND CONTAINER (set in docker-compose.yml, NOT here):
#   DB_HOST=postgres   DB_PORT=5432
# NEVER set DB_HOST=postgres with DB_PORT=5433 — that combination is invalid.
DB_HOST=localhost
DB_PORT=5433
POSTGRES_PUBLISH_PORT=5433
DB_NAME=attendance_trackeroo
DB_USER=dev
DB_PASSWORD=dev123456

# Backend HTTP port (systemd, docker, nginx proxy)
BACKEND_PORT=3001
PORT=3001

# Node Environment
NODE_ENV=production

# Network Configuration
# Set this to your server's IP address or domain name
# Examples: 192.168.1.100, example.com, app.example.com
NGINX_HOST=hada.aqaariq.com
